# Global Settings
font=JetBrainsMono Nerd Font 10
width=300
height=100
margin=10
padding=15
border-size=2
border-radius=12
icons=1
max-icon-size=48

# Lavender Theme Colors
background-color=#1e1e2ee6
text-color=#cdd6f4
border-color=#b4befe
progress-color=over #313244

# Behavior
default-timeout=3000
ignore-timeout=0
layer=overlay
anchor=top-right

# Urgency Levels
[urgency=high]
border-color=#f38ba8
default-timeout=0
